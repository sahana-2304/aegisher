# Backend Firebase Admin credentials
# Download from Firebase Console -> Project Settings -> Service accounts -> Generate new private key
# and place the JSON file at backend/firebase_service_account.json
FIREBASE_CREDENTIALS_PATH=firebase_service_account.json

# Firebase Storage bucket (e.g., your-project.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Alternative: inline JSON (keep escaped and single-line)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# App environment (development | production)
APP_ENV=development

# Optional explicit path for trained risk model artifact
RISK_MODEL_PATH=models/risk_model.pkl

# OpenRouter chatbot (use a free model)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_TIMEOUT_SECONDS=25
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=AegisHer
